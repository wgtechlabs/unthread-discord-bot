{
  "name": "unthread-discord-bot",
  "description": "Turn Discord community servers into real-time support ticket hubs — powered by Unthread.io",
  "version": "1.1.2",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node dist/deploy_commands.js && node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "deploycommand": "pnpm build && node dist/deploy_commands.js",
    "cmd:deploy": "pnpm build && node dist/command_deploy.js",
    "cmd:reset": "pnpm build && node dist/command_reset.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:integration:watch": "vitest watch -c vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "docker:build": "docker build -t unthread-discord-bot .",
    "docker:build:secure": "docker build --no-cache -t unthread-discord-bot .",
    "docker:build:sbom": "docker build --sbom=true --provenance=mode=max -t unthread-discord-bot .",
    "docker:run": "docker run --env-file .env unthread-discord-bot",
    "sbom:generate": "./scripts/generate-sbom.sh"
  },
  "keywords": [],
  "author": "Waren Gonzaga <opensource@warengonzaga.com> (https://warengonzaga.com)",
  "contributors": [
    "WG Tech Labs <opensource@wgtechlabs.com> (https://wgtechlabs.com)"
  ],
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wgtechlabs/unthread-discord-bot.git"
  },
  "bugs": {
    "url": "https://github.com/wgtechlabs/unthread-discord-bot/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@types/ioredis": "^5.0.0",
    "@wgtechlabs/log-engine": "2.3.1",
    "cacheable": "^2.3.4",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "vite": ">=7.1.11",
      "js-yaml": ">=4.1.1"
    }
  }
}
